# Example environment variables for Channels DVR Manager

# Unsplash API key for image search in manual recording creation
VITE_UNSPLASH_CLIENT_ID=your_unsplash_client_id

# Backend API proxy URL (used by nginx to forward /api requests)
API_PROXY_URL=https://your-backend-url.example.com

# Stream Base URL for viewing live TV in the Guide tab
VITE_STREAM_URL=https://your-backend-url.example.com

